# TRACE-AML Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit a .env file with real credentials to version control.

# ── WhatsApp (Evolution API) ──────────────────────────────────────────────────
# API key you set when running Evolution API.
# Used by WhatsAppHandler — never stored in config.yaml
TRACE_AML_WA_API_KEY=your-evolution-api-secret-key-here

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# SMTP password for the configured smtp_user.
# For Gmail: use an App Password, not your account password.
# Used by EmailHandler — never stored in config.yaml
TRACE_AML_SMTP_PASSWORD=your-smtp-password-here

# ── Optional: Config file override ───────────────────────────────────────────
# If not set, TRACE-AML looks for config/config.yaml by default.
# TRACE_AML_CONFIG=config/config.demo.yaml
